<% content_for :head do %>
  <%= stylesheet_link_tag "entries", "data-turbo-track": "reload" %>
<% end %>

<div class="el-page">
  <header class="el-hero">
    <div class="el-hero-inner">
      <h1 class="el-hero-title">エントリーリスト</h1>
      <p class="el-hero-meta">
        エントリー数:
        <span class="el-hero-meta-count"><%= @entries.size + @waitlisted_entries.size %> / <%= Setting.capacity %></span>
      </p>
    </div>
  </header>

  <div class="el-content">
    <div class="el-card">
      <div class="el-card-header">
        <h2 class="el-card-title">参加者</h2>
      </div>
      <table class="el-table">
        <thead>
          <tr>
            <th class="el-col-status el-col-center">ステータス</th>
            <th class="el-col-no el-col-center">No.</th>
            <th>エントリーリストの名前</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each do |entry| %>
            <tr>
              <td class="el-col-status el-col-center"><%= entry.status_label %></td>
              <td class="el-col-no el-col-center"><%= entry.id %></td>
              <td class="el-name"><%= entry.player.player_profile&.entry_list_name %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @waitlisted_entries.any? %>
      <div class="el-card el-card--muted">
        <div class="el-card-header">
          <h2 class="el-card-title">キャンセル待ち</h2>
        </div>
        <table class="el-table">
          <thead>
            <tr>
              <th class="el-col-status el-col-center">キャンセル待ち順位</th>
              <th class="el-col-no el-col-center">No.</th>
              <th>エントリーリストの名前</th>
            </tr>
          </thead>
          <tbody>
            <% @waitlisted_entries.each.with_index(1) do |entry, i| %>
              <tr>
                <td class="el-col-status el-col-center"><%= i %></td>
                <td class="el-col-no el-col-center"><%= entry.id %></td>
                <td class="el-name"><%= entry.player.player_profile&.entry_list_name %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
