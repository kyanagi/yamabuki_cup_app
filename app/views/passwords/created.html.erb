<% content_for :head do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">メール送信完了</h1>

    <div class="auth-flash auth-flash--success">
      <p class="auth-flash-heading">パスワード再設定のメールを送信しました</p>
      <p class="auth-flash-body">メールに記載されているリンクをクリックして、新しいパスワードを設定してください。</p>
    </div>

    <div class="auth-tips">
      <p class="auth-tips-heading">メールが届かない場合</p>
      <ul class="auth-tips-list">
        <li>入力されたメールアドレスに誤りがある可能性があります</li>
        <li>迷惑メールフォルダに分類されている可能性があります</li>
      </ul>
      <p>上記をご確認いただき、メールが見つからない場合は再度お試しください。</p>
    </div>

    <div class="auth-footer">
      <div class="auth-footer-link">
        <%= link_to "ログインページに戻る", new_session_path %>
      </div>
      <div class="auth-footer-link">
        <%= link_to "再設定をやり直す", new_password_path %>
      </div>
    </div>
  </div>
</div>
