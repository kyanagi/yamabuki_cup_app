<% content_for :head do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">新しいパスワードの設定</h1>

    <% if flash[:alert] %>
      <div class="auth-flash auth-flash--danger">
        <%= flash[:alert] %>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="auth-flash auth-flash--success">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= form_with url: password_path(params[:token]), method: :put, local: true do |form| %>
      <div class="auth-form">
        <div class="auth-field">
          <%= form.label :password, "新しいパスワード", class: "auth-label" %>
          <%= form.password_field :password,
                required: true,
                autocomplete: "new-password",
                placeholder: "新しいパスワードを入力",
                maxlength: 72,
                class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= form.label :password_confirmation, "パスワード確認", class: "auth-label" %>
          <%= form.password_field :password_confirmation,
                required: true,
                autocomplete: "new-password",
                placeholder: "パスワードを再入力",
                maxlength: 72,
                class: "auth-input" %>
          <p class="auth-help">確認のため、同じパスワードを再度入力してください。</p>
        </div>

        <%= form.submit "パスワードを更新", class: "auth-submit" %>
      </div>
    <% end %>
  </div>
</div>
