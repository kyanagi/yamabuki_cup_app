<% content_for :head do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">パスワード再設定</h1>
    <p class="auth-subtitle">登録されたメールアドレスにパスワード再設定メールを送信します。</p>

    <% if flash[:alert] %>
      <div class="auth-flash auth-flash--danger">
        <%= flash[:alert] %>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="auth-flash auth-flash--success">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <%= form_with url: passwords_path, local: true do |form| %>
      <div class="auth-form">
        <div class="auth-field">
          <%= form.label :email, "メールアドレス", class: "auth-label" %>
          <%= form.email_field :email,
                required: true,
                autofocus: true,
                autocomplete: "username",
                placeholder: "yamabuki@example.com",
                value: params[:email],
                class: "auth-input" %>
          <p class="auth-help">登録時に使用したメールアドレスを入力してください。</p>
        </div>

        <%= form.submit "再設定メールを送信", class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <div class="auth-footer-link">
        <%= link_to "ログインに戻る", new_session_path %>
      </div>
    </div>
  </div>
</div>
