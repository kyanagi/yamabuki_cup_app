<%# locals: (f:, placeholder:, help_text:) %>
<div class="auth-field">
  <%= f.label :password, "パスワード", class: "auth-label" %>
  <%= f.password_field :password,
        class: "auth-input",
        data: { entry_form_target: "formElement password" },
        autocomplete: "new-password",
        placeholder: placeholder %>
  <p class="auth-help"><%= help_text %></p>
  <p class="auth-help--danger" data-entry-form-target="errorElement passwordError"></p>
</div>
