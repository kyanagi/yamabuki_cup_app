<% content_for :head do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">ログイン</h1>
    <p class="auth-subtitle">
      エントリー済みでない方は<%= link_to "こちらから新規エントリー", new_registration_path %>できます。
    </p>

    <%= form_with url: session_path, data: { turbo: false } do |f| %>
      <% if notice %>
        <div class="auth-flash auth-flash--success">
          <%= notice %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="auth-flash auth-flash--danger">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <div class="auth-form">
        <div class="auth-field">
          <%= f.label :email, "メールアドレス", class: "auth-label" %>
          <%= f.email_field :email, class: "auth-input", autocomplete: "email", placeholder: "yamabuki@example.com" %>
        </div>

        <div class="auth-field">
          <%= f.label :password, "パスワード", class: "auth-label" %>
          <%= f.password_field :password, class: "auth-input", autocomplete: "current-password" %>
        </div>

        <%= f.submit "ログイン", class: "auth-submit" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <div class="auth-footer-link">
        <%= link_to "パスワードを忘れた方", new_password_path %>
      </div>
    </div>
  </div>
</div>
