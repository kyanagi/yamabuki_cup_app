<% content_for :head do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">エントリーキャンセル</h1>
    <p class="auth-subtitle">
      エントリーを取り消す場合は、下の入力欄に「キャンセル」と入力して実行してください。
    </p>

    <%= form_with model: @entry_cancellation_form, url: cancel_home_entry_path, method: :patch do |f| %>
      <% if @entry_cancellation_form.errors.any? %>
        <div class="auth-flash auth-flash--danger">
          <ul class="auth-error-list">
            <% @entry_cancellation_form.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="auth-form">
        <div class="auth-field">
          <%= f.label :confirmation_text, "確認入力", class: "auth-label" %>
          <%= f.text_field :confirmation_text, class: "auth-input", autocomplete: "off" %>
        </div>

        <div class="auth-form-footer">
          <%= link_to "エントリー内容の変更に戻る", edit_home_player_profile_path, class: "auth-btn-cancel" %>
          <%= f.submit "エントリーをキャンセルする", class: "auth-btn-submit auth-btn-submit--danger" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
