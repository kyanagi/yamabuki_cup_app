<% content_for :head do %>
  <%= stylesheet_link_tag "auth", "data-turbo-track": "reload" %>
<% end %>

<div class="auth-page">
  <div class="auth-card auth-card--wide" data-controller="entry-form modal" data-entry-form-edit-mode-value="true">
    <h1 class="auth-title">エントリー内容の変更</h1>

    <%= form_with model: @player_profile_edit, url: home_player_profile_path, method: :patch do |f| %>
      <% if notice %>
        <div class="auth-flash auth-flash--success">
          <%= notice %>
        </div>
      <% end %>
      <% if @player_profile_edit.errors.any? %>
        <div class="auth-flash auth-flash--danger">
          <ul class="auth-error-list">
            <% @player_profile_edit.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="auth-form">
        <%= render "shared/entry_form/email_field", f: f %>
        <%= render "shared/entry_form/password_field", f: f,
              placeholder: "変更する場合のみ入力してください",
              help_text: "パスワードを変更する場合のみ入力してください。空白の場合は変更されません。" %>
        <%= render "shared/entry_form/name_fields", f: f %>
        <%= render "shared/entry_form/name_kana_fields", f: f %>
        <%= render "shared/entry_form/entry_list_name_field", f: f %>
        <%= render "shared/entry_form/playing_staff_field", f: f %>

        <%# その他 %>
        <div class="auth-field">
          <%= f.label :notes, "その他", class: "auth-label" %>
          <%= f.text_area :notes,
                rows: 4,
                class: "auth-textarea",
                data: { entry_form_target: "formElement notes" } %>
          <p class="auth-help">その他、主催者への連絡事項などありましたら入力してください。</p>
        </div>

        <%# ボタン %>
        <div class="auth-form-footer">
          <%= link_to "マイページに戻る", home_path, class: "auth-btn-cancel" %>
          <%= button_tag "確認する",
                class: "auth-btn-submit",
                data: {
                  action: "entry-form#validate:prevent entry-form#updateConfirmationDisplay:prevent modal#open:prevent"
                } %>
        </div>
      </div>

      <%= render "shared/entry_form/confirmation_modal", f: f,
            description: "以下の内容で更新します。",
            submit_label: "更新する",
            show_password: true,
            show_notes: true %>
    <% end %>

    <% if Current.player.entry&.cancellable? %>
      <div class="auth-footer">
        <%= link_to "エントリーをキャンセルしたい方はこちら", cancel_home_entry_path, class: "auth-cancel-entry-link" %>
      </div>
    <% end %>
  </div>
</div>
